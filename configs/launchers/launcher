_launch() {
  local \
    _opts=() \
    _videogame_launcher_opts=()
  _opts=(
    "$@"
  )
  _videogame_launcher_opts+=(
    -e
      "%_game_launcher%"
    -l
      "%_game_language%"
    -p
      "%_game_platform%"
    "${_opts[@]}"
  )
  videogame-launcher \
    "${_videogame_launcher_opts[@]}" \
    "%_app_id%"
}

_opts=(
  "$@"
)
_launch \
  "${_opts[@]}"

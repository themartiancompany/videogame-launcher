[Desktop Entry]
Name=%_title% (%_uuid%)
Comment=%_pkgdesc%
Type=Application
TryExec=duckstation-qt
Exec=%_pkgbase%
Icon=%_app_id%-%_uuid%
Terminal=false
Categories=Game;
Keywords=PSX
Actions=preferences;fullscreen;

[Desktop Action fullscreen]
Name=Launch in fullscreen
Exec=%_pkgbase% -f

[Desktop Action preferences]
Name=Preferences
Exec=duckstation-qt

X-Desktop-File-Install-Version=0.26

[Desktop Entry]
Name=%_game_title%
Comment=%_game_pkgdesc%
Type=Application
TryExec=snes9x
Exec=%_game_command%
Icon=%_app_id%-%_game_uuid%
Terminal=false
Categories=Game;
Keywords=SNES
Actions=preferences;fullscreen;

[Desktop Action fullscreen]
Name=Launch in fullscreen
Exec=%_game_command% -fullscreen

[Desktop Action preferences]
Name=Preferences
Exec=snes9x

X-Desktop-File-Install-Version=0.26

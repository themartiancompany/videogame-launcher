_pcsx2_requirements() {
  local \
    _pcsx2 \
    _pcsx2_pkgname
  # Maybe at some point Android
  # will be blessed with PlayStation 2
  # support.
  _pcsx2="$(
    _pcsx2_auto_detect)"
  _pcsx2_pkgname="${_pcsx2}"
  if [[ "${_pcsx2}" == "PCSX2" ]]; then
    _pcsx2_pkgname="pcsx2"
  fi
  _check_cmd \
    "${_pcsx2}" \
    "${_pcsx2_pkgname}"
  if [[ ! -d "$(_usr_get)/share/ps2/bios" ]]; then
    _msg_error \
      "Please install 'ps2-bios'." \
      1
  fi
}

_pcsx2_auto_detect() {
  local \
    _cpuinfo \
    _pcsx2 \
    _sse3 \
    _sse4
  # Maybe at some point Android
  # will be blessed with PlayStation 2
  # support.
  _sse3="$(
    cat \
      "/proc/cpuinfo" |
      grep \
        "^flags" |
        grep \
          "\bsse3\b")"
  _sse4="$(
    cat \
      "/proc/cpuinfo" |
      grep \
        "^flags" |
        grep \
          "\bsse4\b")"
  if [[ "${_sse3}" == "" ]]; then
    _pcsx2="pcsx2-1.6"
  fi
  if [[ "${_sse3}" != "" ]]; then
    _pcsx2="pcsx2-1.7"
  fi
  if [[ "${_sse4}" != "" ]]; then
    _pcsx2="PCSX2"
  fi
  echo \
    "${_pcsx2}"
}


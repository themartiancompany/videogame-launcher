_cyberstorm_setup() {
  local \
    _cyberstorm \
    _cyberstorm_link \
    _cyberstorm_target \
    _kickstarts
  _kickstarts="${_config_dir_user}/Kickstarts"
  _cyberstorm="cyberstormppc.rom"
  _cyberstorm_target="$(
    _usr_get)/share/amiga/cyberstorm/${_cyberstorm}"
  _cyberstorm_link="${_kickstarts}/${_cyberstorm}"
  if [[ ! -e "${_kickstarts}/${_cyberstorm}" ]]; then
    _msg=(
      "Linking system Amiga Cyberstorm"
      "Expansion Rom image in"
      "kickstarts directory '${_kickstarts}'."
    )
    _msg_info \
      "${_msg[*]}"
    mkdir \
      -p \
      "${_kickstarts}"
    ln \
      -s \
      "${_cyberstorm_target}" \
      "${_cyberstorm_link}" || \
    true
  fi
}

_settings_fs-uae_create() {
  local \
    _app_id="${1}" \
    _base_dir="${2}" \
    _game_path="${3}" \
    _configs \
    _configs_game \
    _game_dir \
    _msg=() \
    _settings \
    _settings_template \
    _share \
    _usr
  _msg=(
    "Creating game configuration."
  )
  _msg_info \
    "${_msg[*]}"
  _usr="$(
    _usr_get)"
  _game_file_name="$(
    basename \
      "${_game_path}")"
  _share="${_usr}/share"
  _configs="${_share}/${app_name}/configs"
  _settings_template="${_configs}/fs-uae/template.fs-uae"
  _configs_game="${_base_dir}/Configurations"
  _settings="${_configs_game}/${_game_file_name}.fs-uae"
  _msg=(
    "Preparing FS UAE config file."
  )
  _msg_info \
    "${_msg[*]}"
  mkdir \
    -p \
    "${_configs_game}"
  cp \
    "${_settings_template}" \
    "${_settings}"
  sed \
    -i \
    "s|%_base_dir%|${_base_dir}|g" \
    "${_settings}"
  sed \
    -i \
    "s|%_floppy_drive%|${_game_path}|g" \
    "${_settings}"
}


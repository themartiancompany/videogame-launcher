_pcsx2_launch() {
  local \
    _app_id="${1}" \
    _lang="${2}" \
    _settings="${3}" \
    _fullscreen="${4}" \
    _pcsx2_opts=() \
    _game_path \
    _pcsx2 \
    _pcsx2_ver \
    _game_dir \
    _settings_system \
    _config_dir_user \
    _cache_dir
  _cache_dir="${HOME}/.cache/${_app_id}"
  _config_dir_user="${HOME}/.config/${_app_id}"
  _pcsx2="$(
    _pcsx2_auto_detect)"
  _pcsx2_ver="$(
    basename \
      "${_pcsx2}")"
  _game_path_get \
    "${_app_id}" \
    "${_lang}"
  _msg_info \
    "Running '${_game_path}'."
  _game_dir="$(
    dirname \
      "${_game_path}")"
  if [[ ! -d "${_config_dir_user}" ]]; then
    _msg=(
      "Creating game configuration."
    )
    _msg_info \
      "${_msg[*]}"
    _settings_system="${_game_dir}/inis"
    if [[ ! -d "${_settings_system}" ]]; then
      _msg=(
        "No game specific configuration"
        "files, using system defaults."
      )
      _msg_info \
        "${_msg[*]}"
      _settings_system="$(
        _usr_get)/share/${app_name}/configs"
    fi
    mkdir \
      -p \
      "${_config_dir_user}"
    cp \
      -r \
      "${_settings_system}/"* \
      "${_config_dir_user}"
  fi
  _pcsx2_opts+=(
    --fullboot
    --nogui
  )
  if [[ ! -e "${_cache_dir}/bios" ]]; then
    mkdir \
      -p \
      "${_cache_dir}/bios"
    cp \
      "$(_usr_get)/share/ps2/bios/"* \
      "${_cache_dir}/bios"
  fi
  if [[ -e "${_config_dir_user}/${_pcsx2}" ]]; then
    _bios_file="ps2-0120e-20000902.bin"
    sed \
      -i \
      "s|%_bios_dir%|${_cache_dir}/bios|g" \
      "${_config_dir_user}/${_pcsx2}/PCSX2_ui.ini"
    sed \
      -i \
      "s|%_bios_file%|${_bios_file}|g" \
      "${_config_dir_user}/${_pcsx2}/PCSX2_ui.ini"
    _pcsx2_opts+=(
      --cfgpath
        "${_config_dir_user}/${_pcsx2}"
    )
  fi
  if [[ "${_fullscreen}" == "y" ]]; then
    _pcsx2_opts+=(
      --fullscreen
    )
  fi
  "${_pcsx2}" \
    "${_pcsx2_opts[@]}" \
    "${_game_path}"
}


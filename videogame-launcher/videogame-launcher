_fceux_launch() {
  local \
    _app_id="${1}" \
    _lang="${2}" \
    _fullscreen="${3}" \
    _game_path \
    _fceux_bios \
    _fceux_home \
    _fceux_sys_bios \
    _fceux_opts=() \
    _share \
    _msg=()
  _fceux_home="${HOME}/.fceux"
  _fceux_bios="${_fceux_home}/disksys.rom"
  _game_path_get \
    "${_app_id}" \
    "${_lang}"
  if [[ "${_fullscreen}" == "y" ]]; then
    _fceux_opts+=(
      --fullscreen
    )
  fi
  if [[ "${_game_platform}" == "famicom" ]]; then
    if [[ ! -e "${_fceux_bios}" ]]; then
      _share="$(
        _get_usr)/share"
      _fceux_sys_bios="${_share}/famicom/bios/DISKSYS.ROM"
      if [[ ! -e "${_fceux_sys_bios}" ]]; then
        _msg=(
          "FamiCom BIOS must be installed"
          "at location '${_fceux_sys_bios}'."
          "If you don't know where to get"
          "one you can type"
          "'ur famicom-bios'."
          "For more information check"
          "<https://github.com/themartiancompany/ur>."
        )
        _msg_error \
          "${_msg[*]}" \
          1
      fi
      if [[ ! -d "${_fceux_home}" ]]; then
        mkdir \
          -p \
          "${_fceux_home}"
      fi
      cp \
        "${_fceux_sys_bios}" \
        "${_fceux_bios}"
    fi
  fi
  fceux \
    "${_fceux_opts[@]}" \
    "${_game_path}"
}


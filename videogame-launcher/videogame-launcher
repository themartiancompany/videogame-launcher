_retroarch_platform_auto_detect() {
  local \
    _game_path \
    _game_lang \
    _game_dir \
    _platforms=() \
    _msg=()
  _game_lang="${game_lang}"
  if [[ -v "override_game_lang" ]]; then
    _game_lang="${override_game_lang}"
  fi
  _msg=(
    "Retroarch platform auto-detect."
  )
  _msg_info \
    "${_msg[*]}"
  _game_path_get \
      "${app_id}" \
      "${_game_lang}"
  _msg=(
    "Game path: ${_game_path}."
  )
  _msg_info \
    "${_msg[*]}"
  if [[ "${_game_path}" == *".EXE" ]]; then
    _platform="dos"
  elif [[ "${_game_path}" == *".bin" || \
          "${_game_path}" == *".cue" ]]; then
    _platform="playstation"
  elif [[ "${_game_path}" == *".cdi" ]]; then
    _platform="dreamcast"
  elif [[ "${_game_path}" == *".fds" ]]; then
    _platform="famicom"
  elif [[ "${_game_path}" == *".gbc" || \
          "${_game_path}" == *".gb" ]]; then
    _platform="gameboy"
  elif [[ "${_game_path}" == *".img" ]]; then
    _platform="mame"
  elif [[ "${_game_path}" == *".iso" ]]; then
    _platform="playstation2"
  elif [[ "${_game_path}" == *".mx2" ]]; then
    _platform="msx"
  elif [[ "${_game_path}" == *".nes" ]]; then
    _platform="nes"
  elif [[ "${_game_path}" == *".smc" ]]; then
    _platform="snes"
  elif [[ "${_game_path}" == *".swf" ]]; then
    _platform="flashplayer"
  elif [[ "${_game_path}" == *".wad" || \
          "${_game_path}" == *".WAD" ]]; then
    _platform="doom"
  elif [[ -d "${_game_path}" ]]; then
    _platform="scummvm"
  elif [[ "${_game_path}" == "" ]]; then
    _game_dir="$(
      _game_dir_get \
        "${app_id}")"
    if [[ "$(ls "${_game_dir}/"*".cdi")" != "" ]]; then
      _msg=(
	"Definitely not gonna have it this way."
      )
      echo \
        "${_msg[*]}"
    fi
  fi
}


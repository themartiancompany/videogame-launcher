_usage() {
  local \
    _exit="${1}" \
    _usage_text
  IFS='' \
    read \
      -r \
      -d '' \
      _usage_text << \
        ENDUSAGETEXT || true

Seamlessly launch videogames.

Usage:
  ${app_name}
    <app-id>

  options:
     -e <game-launcher>     It can be 'doomretro',
                            'dosbox', 'duckstation',
                            'fceux', 'flashplayer',
                            'flycast', 'fs-uae', 'gearboy',
                            'love', 'mame', 'openmsx',
                            'retroarch', 'ruffle',
                            'pcsx2', 'scummvm',
                            'snes9x'.
                            Default: ${game_launcher}
     -p <game-platform>     Game platform. It can be
                            'amiga, 'apple2', 'arcade',
                            'doom', 'dreamcast',
                            'famicom', 'flash',
                            'gameboy', 'love',
                            'mame', 'mame2003, 'mame2010,
                            'msx', 'nes', 'nintendo64',
                            'playstation', 'playstation2',
                            'scummvm' or 'snes'.
                            Default: ${game_platform}
     -l <game-lang>         Game languages.
                            Default: ${game_lang}
     -H                     Enables on-screen controller HUD.
                            Default: ${game_hud}
     -s <game-settings>     Depending on the selected game launcher
                            it can be a Duckstation settings file
			    or the name for a SCUMMVM game
                            platform.
                            Default: ${game_settings}
     -f                     Launch the game in full-screen.
                            Default: ${fullscreen_enabled}

     -h                     This message.
     -c                     Enable color output
     -v                     Enable verbose output
ENDUSAGETEXT
  _printf \
    '%s\n' \
    "${_usage_text}"
  exit \
    "${_exit}"
}


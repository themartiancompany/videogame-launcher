_mame_opts_get() {
  local \
    _data_dir \
    _os_img \
    _game_img
  if [[ "${_game_platform}" == "apple2" ]]; then
    _mame_opts+=(
      -rompath
        "${_rom_dir}"
      -swpath
        "${_rom_dir}"
      apple2e
      # -flop1
      #   "${_flop1}"
      "${_game_name}"
    )
  elif [[ "${_game_platform}" == "system7" ]]; then
    _os_img="${_cache_dir}/system7_0_1-color.img"
    _game_img="${_cache_dir}/${_game_name}"
    _mame_opts+=(
      maclc3
      -rompath
        "${_cache_dir}"
      -swpath
        "${_cache_dir}"
      -hard1
        "${_os_img}"
    )
    if [[ "${_os_img}" == "${_game_img}" ]]; then
      _msg=(
        "The videogame is the OS itself."
      )
      _msg_info \
        "${_msg[*]}"
    else
      _mame_opts+=(
        -flop1
          "${_game_img}"
      )
    fi
  else
    _mame_opts+=(
      -rompath
        "${_rom_dir}"
      "${_game_name}"
    )
  fi
}

_mame_writable_setup() {
  local \
    _data_dir \
    _fw_dir \
    _os_dir \
    _os_img
  _data_dir="$(
    _usr_get)/share"
  _cache_dir="${HOME}/.cache/${_app_id}"
  if [[ ! -d "${_cache_dir}" ]]; then
    _msg=(
      "Copying System 7 and game image onto"
      "user home directory."
    )
    _msg_info \
      "${_msg[*]}"
    mkdir \
      -p \
      "${_cache_dir}"
    if [[ "${_game_platform}" == "system7" ]]; then
      _fw_dir="${_data_dir}/mac-lc/mac-lc"
      _os_dir="${_data_dir}/system7/system7"
      _os_img="${_os_dir}/system7_0_1-color.img"
      cp \
        -r \
        "${_fw_dir}" \
        "${_cache_dir}/maclc520"
      cp \
        -r \
        "${_os_dir}/"* \
        "${_cache_dir}"
      cp \
        "${_rom_dir}/"* \
        "${_cache_dir}"
    fi
  fi
}


_globals
_global_variables
_requirements
while \
  getopts \
    'e:p:l:H:s:f:wcvh?' \
    arg; do
  case \
    "${arg}" in
    e) \
      override_game_launcher="${OPTARG}" ;;
    p) \
      override_game_platform="${OPTARG}" ;;
    l) \
      override_game_lang="${OPTARG}" ;;
    H) \
      override_game_hud="y" ;;
    s) \
      override_game_settings="${OPTARG}" ;;
    f) \
      override_fullscreen_enabled="y" ;;
    w) \
      override_game_writable="y" ;;
    c) \
      override_color="y" ;;
    v) \
      override_quiet="n" ;;
    h|?) \
      _set_overrides
      _usage \
        0 ;;
    *) \
      _msg_error \
        "Invalid argument '${arg}'" \
        0
      _usage \
        1 ;;
  esac
done
shift \
  $(( \
    OPTIND - 1 \
  ))
if (( $# < 1 )); then
  _msg_error \
    "No Application ID given." \
    0
  _set_overrides
  _usage \
    1
fi
if (( 0 < $# )); then
  app_id="${1}"
fi
_set_overrides
_show_config
app_opts=(
  "${app_id}"
  "${game_launcher}"
  "${game_platform}"
  "${game_lang}"
  "${game_hud}"
  "${game_settings}"
  "${game_writable}"
  "${fullscreen_enabled}"
)
_videogame_launcher \
  "${app_opts[@]}"

_game_path_get() {
  local \
    _app_id="${1}" \
    _lang="${2}" \
    _game_dir \
    _path \
    _msg=()
  _game_dir="$(
    _game_dir_get \
      "${_app_id}")"
  _path="${_game_dir}/${_lang}"
  if [[ ! -d "${_path}" ]]; then
    if [[ ! -f "${_path}" ]]; then
      _path="${_game_dir}/any"
      _msg=(
        "No support for language '${_lang}'."
        "Running default language 'any'."
      )
      _msg_warning \
        "${_msg[*]}"
      if [[ ! -d "${_path}" ]]; then
        _msg=(
          "Found no file to launch."
        )
	_msg_error \
          "${_msg[*]}" \
	  0
      fi
    fi
    _game_path="$(
      cat \
        "${_path}" || \
      true)"
  elif [[ -d "${_path}" ]]; then
    _game_path="${_path}"
  fi
  _game_path="$(
    realpath \
      "${_game_path}")"
}


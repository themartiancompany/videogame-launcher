_desktop_file_create() {
  local \
    _game_title="${1}" \
    _app_id="${2}" \
    _game_command="${3}" \
    _game_pkgdesc="${4}" \
    _game_uuid="${5}" \
    _game_launcher="${6}" \
    _game_platform="${7}" \
    _game_lang="${8}" \
    _template_file="${9}" \
    _output_file="${10}" \
    _usr \
    _templates_dir \
    _msg=()
  _msg=(
    "Preparing '${_game_title}' desktop file."
  )
  _msg_info \
    "${_msg[*]}"
  if [[ "${_template_file}" == "" ]]; then
    _usr="$( \
      _usr_get)"
    _templates_dir="${_usr}/share/videogame-launcher/templates"
    _template_file="${_templates_dir}/${_game_platform}.desktop"
  fi
  if [[ "${_output_file}" == "" ]]; then
    _output_file="$( \
      pwd)/${_app_id}.desktop"
  fi
  _msg=(
    "Copying template"
    "file '${_template_file}'."
  )
  _msg_info \
    "${_msg[*]}"
  cp \
    "${_template_file}" \
    "${_output_file}"
  sed \
    -i \
    "s/%_game_title%/${_game_title}/g" \
    "${_output_file}"
  sed \
    -i \
    "s/%_game_pkgdesc%/${_game_pkgdesc}/g" \
    "${_output_file}"
  sed \
    -i \
    "s/%_app_id%/${_app_id}/g" \
    "${_output_file}"
  sed \
    -i "s/%_game_uuid%/${_game_uuid}/g" \
    "${_output_file}"
  sed \
    -i \
    "s/%_game_launcher%/${_game_launcher}/g" \
    "${_output_file}"
  sed \
    -i \
    "s/%_game_platform%/${_game_platform}/g" \
    "${_output_file}"
  sed \
    -i \
    "s/%_game_lang%/${_game_lang}/g" \
    "${_output_file}"
  sed \
    -i \
    "s/%_game_command%/${_game_command}/g" \
    "${_output_file}"
}

_settings_duckstation_create() {
  local \
    _game_dir \
    _os \
    _rom_dir \
    _rom_install_dir \
    _settings_template \
    _share \
    _usr
  _os="$( \
    uname \
      -o)"
  _usr="$( \
    _usr_get)"
  _share="${_usr}/share"
  _settings_template="${_share}/videogame-launcher/configs/duckstation/settings.ini"
  _game_dir="${_usr}/games/${_app_id}"
  if [[ "${_os}" == "GNU/Linux" ]]; then
    _rom_dir="${_game_dir}"
  elif [[ "${_os}" == "Android" ]]; then
    _rom_dir="/storage/emulated/0/Android/media/${_app_id}"
  fi
  _msg_info \
    "Preparing Duckstation config file."
  cp \
    "${_settings_template}" \
    "${_game_settings}"
  sed \
    -i \
    "s|%_share%|${_share}|g" \
    "${_game_settings}"
  sed \
    -i \
    "s|%_game_dir%|${_rom_dir}|g" \
    "${_game_settings}"
}

_command_create() {
  local \
    _game_title="${1}" \
    _app_id="${2}" \
    _game_command="${3}" \
    _game_uuid="${4}" \
    _game_launcher="${5}" \
    _game_platform="${6}" \
    _game_lang="${7}" \
    _command_file="${8}" \
    _command_template \
    _msg=()
  _command_template="$( \
    _get_usr)/share/videogame-launcher/configs/launchers/launcher"
  _msg=(
    "Preparing command-line launcher."
  )
  _msg_info \
    "${_msg[*]}"
  cp \
    "${_command_template}" \
    "${_command_file}"
  sed \
    -i \
    "s/%_app_id%/${_app_id}/g" \
    "${_command_file}"
  sed \
    -i \
    "s/%_game_launcher%/${_game_launcher}/g" \
    "${_command_file}"
  sed \
    -i \
    "s/%_game_language%/${_game_lang}/g" \
    "${_command_file}"
  sed \
    -i \
    "s/%_game_platform%/${_game_platform}/g" \
    "${_command_file}"
  chmod \
    +x \
    "${_command_file}"
}

_videogame_launcher_create() {
  local \
    _game_title="${1}" \
    _app_id="${2}" \
    _game_command="${3}" \
    _game_pkgdesc="${4}" \
    _game_uuid="${5}" \
    _game_launcher="${6}" \
    _game_platform="${7}" \
    _game_lang="${8}" \
    _template_file="${9}" \
    _desktop_file="${10}" \
    _game_settings="${11}" \
    _command_file="${12}" \
    _fullscreen_enabled="${13}" \
    _game_command
  _game_command="$( \
    basename \
      "${_command_file}")"
  _desktop_file_create \
    "${_game_title}" \
    "${_app_id}" \
    "${_game_command}" \
    "${_game_pkgdesc}" \
    "${_game_uuid}" \
    "${_game_launcher}" \
    "${_game_platform}" \
    "${_game_lang}" \
    "${_template_file}" \
    "${_desktop_file}"
  _command_create \
    "${_game_title}" \
    "${_app_id}" \
    "${_game_command}" \
    "${_game_uuid}" \
    "${_game_launcher}" \
    "${_game_platform}" \
    "${_game_lang}" \
    "${_command_file}"
  if [[ "${_game_launcher}" == "duckstation" ]]; then
    _settings_duckstation_create
  fi
}


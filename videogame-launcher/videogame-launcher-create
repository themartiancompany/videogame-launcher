_retroarch_platform_auto_detect() {
  local \
    _game_path \
    _game_lang \
    _game_dir \
    _platforms=()
  _game_lang="${game_lang}"
  if [[ -v "override_game_lang" ]]; then
    _game_lang="${override_game_lang}"
  fi
  _msg_info \
    "Retroarch platform auto-detect."
  _msg_info \
    "Game path: ${_game_path}."
  if [[ "${_game_path}" == *".nes" ]]; then
    _platform="nes"
  elif [[ "${_game_path}" == *".gbc" || \
	  "${_game_path}" == *".gb" ]]; then
    _platform="gameboy"
  elif [[ "${_game_path}" == *".bin" || \
	  "${_game_path}" == *".cue" ]]; then
    _platform="playstation"
  elif [[ "${_game_path}" == *".iso" ]]; then
    _platform="playstation2"
  elif [[ "${_game_path}" == *".wad" || \
	  "${_game_path}" == *".WAD" ]]; then
    _platform="doom"
  elif [[ -d "${_game_path}" ]]; then
    _platform="scummvm"
  elif [[ "${_game_path}" == "" ]]; then
    _game_dir="$( \
      _game_dir_get \
        "${app_id}")"
    if [[ "$(ls "${_game_dir}/"*".cdi")" != "" ]]; then
      ""
    fi
  fi
}

_game_platform_auto_detect() {
  local \
    _platform
  _platform=""
  if [[ "${game_launcher}" == "doomretro" ]]; then
    _platform="doom"
  elif [[ "${game_launcher}" == "duckstation" ]]; then
    _platform="playstation"
  elif [[ "${game_launcher}" == "fceux" ]]; then
    _platform="nes"
  elif [[ "${game_launcher}" == "gearboy" ]]; then
    _platform="gameboy"
  elif [[ "${game_launcher}" == "mame" ]]; then
    _platform="arcade"
  elif [[ "${game_launcher}" == "love" ]]; then
    _platform="love"
  elif [[ "${game_launcher}" == "retroarch" ]]; then
    _retroarch_platform_auto_detect
  elif [[ "${game_launcher}" == "$(_lower \
	                             "pcsx2")"* ]]; then
    _platform="playstation2"
  elif [[ "${game_launcher}" == "scummvm" ]]; then
    _platform="scummvm"	
  fi
  _set_override \
    "game" \
    "platform" \
    "${_platform}"
}

_template_file_auto_detect() {
  local \
    _configs \
    _template_file
  _configs="$( \
    _get_usr)/share/videogame-launcher/configs"
  _template_file="${_configs}/launchers/${game_platform}-template.desktop"
  _set_override \
    "template" \
    "file" \
    "${_template_file}"
}

_set_overrides() {
  local \
    _app_id \
    _pwd
  _pwd="$( \
    pwd)"
  _app_id="${app_id}"
  if [[ -v override_quiet ]]; then
    quiet="${override_quiet}"
  elif [[ -z "${quiet}" ]]; then
    quiet="y"
  fi
  if [[ -v override_color ]]; then
    color="${override_color}"
  elif [[ -z "${color}" ]]; then
    color="n"
  fi
  _set_override \
    "creation" \
    "date" \
    "$(_get_date_human)"
  _game_launcher_auto_detect
  _game_platform_auto_detect
  _game_lang_auto_detect
  _template_file_auto_detect
  _set_override \
    "desktop" \
    "file" \
    "${_pwd}/${app_id}.desktop"
  _set_override \
    "command" \
    "file" \
    "${_pwd}/${_app_id}"
  _set_override \
    "game" \
    "settings" \
    "${_pwd}/${_app_id}.settings.ini"
  _set_override \
    "fullscreen" \
    "enabled" \
    "n"
  _set_override \
    "game" \
    "uuid" \
    ""
  _set_override \
    "game" \
    "title" \
    "${_app_id}"
  _set_override \
    "game" \
    "pkgdesc" \
    "Videogame for ${game_platform}."
}

_globals
_global_variables
_requirements
while \
  getopts \
    'U:e:p:l:t:s:fd:m:o:cvh?' \
    arg; do
  case \
    "${arg}" in
    U) \
      override_game_uuid="${OPTARG}" ;;
    e) \
      override_game_launcher="${OPTARG}" ;;
    p) \
      override_game_platform="${OPTARG}" ;;
    l) \
      override_game_lang="${OPTARG}" ;;
    t) \
      override_game_title="${OPTARG}" ;;
    s) \
      override_game_settings="${OPTARG}" ;;
    f) \
      override_fullscreen_enabled="y" ;;
    d) \
      override_game_pkgdesc="${OPTARG}" ;;
    m) \
      override_template_file="${OPTARG}" ;;
    o) \
      override_command_file="${OPTARG}" ;;
    c) \
      override_color="y" ;;
    v) \
      override_quiet="n" ;;
    h|?) \
      _set_overrides
      _usage \
        0 ;;
    *) \
      _msg_error \
        "Invalid argument '${arg}'" \
        0
      _usage \
        1 ;;
  esac
done
shift \
  $(( \
    OPTIND - 1 \
  ))
if (( $# < 1 )); then
  _msg_error \
    "No Application ID given." \
    0
  _set_overrides
  _usage \
    1
fi
if (( 0 < $# )); then
  app_id="${1}"
fi
_set_overrides
_show_config
app_opts=(
  "${game_title}"
  "${app_id}"
  "${game_pkgdesc}"
  "${game_uuid}"
  "${game_launcher}"
  "${game_platform}"
  "${game_lang}"
  "${template_file}"
  "${desktop_file}"
  "${game_settings}"
  "${command_file}"
  "${fullscreen_enabled}"
)
_videogame_launcher_create \
  "${app_opts[@]}"

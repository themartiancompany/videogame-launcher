_usage() {
  local \
    _exit="${1}" \
    _usage_text
  IFS='' \
    read \
      -r \
      -d '' \
      _usage_text << \
        ENDUSAGETEXT || true

Seamlessly create videogame launchers.

Usage:
  ${app_name}
    <app_id>

  options:
     -e <game_launcher>     It can be 'doomretro',
                            'duckstation',
                            'fceux', 'gearboy', 'flycast',
                            'love', 'mame', 'retroarch',
                            'pcsx2', 'scummvm'.
                            Default: ${game_launcher}
     -p <game_platform>     Game platform. It can be
                            'playstation', 'arcade',
       	                    'doom', 'dreamcast', 'love',
                            'mame20'nes', 'nintendo64',
                            'gameboy', 'playstation2'
                            or 'scummvm'.
                            Default: ${game_platform}
     -l <game_lang>         Game languages.
                            Default: ${game_lang}
     -t <game_title>        Game full title.
                            Default: ${game_title}
     -U <game_uuid>         The game platform UUID.
                            Default: ${game_uuid}
     -d <description>       Game launcher description.
                            Default: ${game_pkgdesc}
     -m <template_file>     Template file to use to write
                            the launcher.
                            Default: ${template_file}
     -s <settings_file>     Output launcher's settings
                            file.
                            Default: ${game_settings}
     -o <command_file>      Output command filename.
                            Default: ${command_file}
     -f                     Whether to make the launcher offer
                            to open the game in full-screen.
                            Default: ${fullscreen_enabled}

     -h                     This message.
     -c                     Enable color output
     -v                     Enable verbose output

ENDUSAGETEXT
  _printf \
    '%s\n' \
    "${_usage_text}"
  exit \
    "${_exit}"
}

_game_lang_auto_detect() {
  local \
    _uage \
    _lang
  _set_override \
    "game" \
    "lang" \
    "any"
}

_game_launcher_auto_detect() {
  local \
    _game_platform \
    _launcher \
    _os \
    _msg=()
  _os="$( \
    uname \
      -o)"
  _game_platform=""
  if [[ -v "override_game_platform" ]]; then
    _game_platform="${override_game_platform}"
  fi
  _launcher=""
  _msg=(
    "Detecting game launcher"
    "for platform '${_game_platform}'."
  )
  _msg_info \
    "${_msg[*]}"
  if [[ "${_os}" == "Android" ]]; then
    _launcher="retroarch"
  elif [[ "${_os}" == "GNU/Linux" ]]; then
    _launcher="duckstation"
    if [[ "${_game_platform}" == "arcade" ]]; then
      _launcher="mame"
    elif [[ "${_game_platform}" == "doom" ]]; then
      _launcher="doomretro"
    elif [[ "${_game_platform}" == "gameboy" ]]; then
      _launcher="gearboy"
    elif [[ "${_game_platform}" == "playstation2" ]]; then
      _launcher="pcsx2"
    fi
  fi
  if [[ "${_game_platform}" == "love" ]]; then
    _launcher="love"
  fi
  _set_override \
    "game" \
    "launcher" \
    "${_launcher}"
}

